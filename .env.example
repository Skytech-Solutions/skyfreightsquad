# Copy to .env.local and fill in values. Vars prefixed with VITE_ are exposed to the browser.
# SUPABASE_SERVICE_ROLE_KEY must NEVER be prefixed with VITE_ — it's server-only.

# --- Supabase ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
# VITE_PUBLIC_SITE_URL=https://skyfreightsquad.com

# SMTP credentials are NOT set here. Admins configure them at /admin/settings
# after logging in. Values are stored in the Supabase app_settings table.
